# =============================================
# VARIABLES DE ENTORNO PARA EL SERVIDOR (API SERVERLESS)
# =============================================
# IMPORTANTE: Estas vars van en Vercel Dashboard > Settings > Environment Variables
# NO se añaden al .env local (ese solo es para Vite/navegador)
#
# Las vars con VITE_ son para el frontend (browser)
# Las vars SIN VITE_ son para las funciones serverless de Vercel
# =============================================

# URL de Supabase (igual que VITE_SUPABASE_URL pero sin el prefijo VITE_)
SUPABASE_URL=https://pruiccptamjzemedwhdq.supabase.co

# Service Role Key (SECRETA - NO la anon key)
# La encuentras en: Supabase Dashboard > Settings > API > service_role
# Es diferente de la anon key, tiene más permisos y bypassa las RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  <-- reemplaza con tu clave real
