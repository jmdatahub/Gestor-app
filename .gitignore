scripts/diag2.mjs
scripts/diag_data.mjs
scripts/test_api.mjs

# Vite PWA dev artifacts
**/dev-dist/

# Vite worktree-isolated cache (cacheDir)
client/.vite-redesign/

# Plan operativo de migración (contiene credenciales)
MIGRATION-PLAN.md

# Env files (never commit real secrets)
.env
.env.local
.env.*.local

# Server runtime logs
server_errors.log

# Drizzle kit output (generated, not tracked)
server/db/migrations/*.sql
server/db/migrations/*.snap
