# Dependencies — installed fresh inside the image
node_modules
client/node_modules

# Build artifacts — rebuilt inside the image
dist
client/dist
client/.vite

# Environment files — never bake secrets into the image
.env
.env.*
!.env.example

# Git and CI metadata
.git
.gitignore
.github

# Claude worktrees and local dev tooling
.claude

# Logs and temp files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# OS files
.DS_Store
Thumbs.db

# Editor configs
.vscode
.idea
*.swp
*.swo

# Test output
coverage
client/coverage

# TypeScript build info
*.tsbuildinfo
