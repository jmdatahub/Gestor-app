# Server
# 3002 por convención: el CRM ocupa 3001. Si los dos comparten puerto y cambias
# de proyecto, el frontend del CRM acaba hablando con el backend del Gestor y
# todo da 404. La pre-flight check abortará si ve otro app en este puerto.
SERVER_PORT=3002
NODE_ENV=development
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRY=7d

# Database
DATABASE_URL=postgres://user:password@host:5432/dbname

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:5173

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=My App <noreply@yourdomain.com>
PUBLIC_URL=https://yourdomain.com

# Admin
ADMIN_EMAIL=admin@yourdomain.com

# Telegram Bot
# Token from BotFather
TELEGRAM_BOT_TOKEN=xxxx:yyyy
# Random secret passed when registering webhook via setWebhook (secret_token param)
TELEGRAM_WEBHOOK_SECRET=change-me-random-hex-string

# CRM Sync
CRM_SYNC_SECRET=change-me-random-secret
CRM_SYNC_ORG_NAME=your-org-name
